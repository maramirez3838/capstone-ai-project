backend/dist/
backend/build/

# Environment files — never commit these
.env
.env.local
.env.*.local
frontend/.env.local
backend/.env.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# TypeScript
*.tsbuildinfo

# Source discovery output — working files, not committed
frontend/scripts/discovery-output/

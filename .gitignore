# macOS
.DS_Store

# Claude local settings (machine-specific, not for teammates)
.claude/settings.local.json

# Frontend dependencies and build output
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.vercel/

# Backend dependencies and build output (for when backend is added)

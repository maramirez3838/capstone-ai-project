# STR Comply — Environment Variables
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to git.

# ── Database ───────────────────────────────────────────────────────────────────
# Get from Neon dashboard → Connection string → use the non-pooler URL for migrations,
# pooler URL for runtime. Strip &channel_binding=require if present.
DATABASE_URL=postgresql://username:password@host/database?sslmode=require

# ── Auth ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# The URL your app runs at
AUTH_URL=http://localhost:3001

# ── Email (Resend — magic link auth + compliance monitor reports) ───────────────
RESEND_KEY=

# ── AI (Anthropic — property requirements agent + market refresh agent) ────────
ANTHROPIC_API_KEY=

# ── Mapbox (address autofill + geocoding in /api/search) ──────────────────────
# Get from Mapbox dashboard → Tokens. Also add to Vercel env for production.
NEXT_PUBLIC_MAPBOX_TOKEN=

# ── Compliance Monitor (background agent — off by default) ────────────────────
# Set to true to enable the weekly Vercel cron run
COMPLIANCE_MONITOR_ENABLED=false

# Bearer token protecting /api/cron/compliance-monitor (Vercel injects automatically)
CRON_SECRET=

# Email address that receives the weekly compliance monitor summary report
COMPLIANCE_REPORT_EMAIL=

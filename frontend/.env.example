# STR Comply — Environment Variables
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to git.

# ── Database ──────────────────────────────────────────────────────────────────
# Get this from your Neon project dashboard: https://neon.tech
# Settings → Connection string → copy the "Pooling" connection string
DATABASE_URL=postgresql://username:password@host/database?sslmode=require

# ── Auth (add when NextAuth is wired in) ──────────────────────────────────────
# Generate a secret with: openssl rand -base64 32
# NEXTAUTH_SECRET=

# The URL your app runs at (use http://localhost:3000 for local dev)
# NEXTAUTH_URL=http://localhost:3000

# Email provider for magic link (e.g. Resend)
# RESEND_API_KEY=
# EMAIL_FROM=noreply@your-domain.com
